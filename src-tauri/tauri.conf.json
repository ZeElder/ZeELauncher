{
  "$schema": "https://schema.tauri.app/config/2",

  "productName": "ZeELauncher",
  "version": "0.1.1",
  "identifier": "com.zeelauncher.app",

  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },

  "app": {
    "windows": [
      {
        "title": "ZeELauncher",
        "width": 1280,
        "height": 800,
        "minWidth": 1000,
        "minHeight": 650,
        "resizable": true,
        "fullscreen": false
      }
    ],

    "security": {
      "csp": null
    }
  },

  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,

    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  },

  "plugins": {
    "updater": {
      "pubkey": " D:\\LauncherPerso\\Dev Launcher\\ZeELauncher\\~\\.tauri\\zeelauncher.key.pub",

      "endpoints": [
        "https://github.com/ZeElder/zeelauncher-app/releases/latest/download/latest.json"
      ]
    }
  }
}